{
    "name": "oguzhantogay/philips-hue-client",
    "description": "A modern, fully-featured PHP client for Philips Hue smart lights",
    "type": "library",
    "license": "MIT",
    "keywords": ["philips", "hue", "smart-lights", "iot", "home-automation", "php"],
    "authors": [
        {
            "name": "Oguzhan Togay",
            "email": "ogitog@gmail.com"
        }
    ],
    "require": {
        "php": "^8.0",
        "guzzlehttp/guzzle": "^7.0",
        "ext-json": "*",
        "symfony/console": "^6.0|^7.0",
        "psr/log": "^3.0",
        "react/event-loop": "^1.0",
        "clue/buzz-react": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "mockery/mockery": "^1.5",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "OguzhanTogay\\HueClient\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OguzhanTogay\\HueClient\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/hue"
    ],
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage",
        "analyse": "vendor/bin/phpstan analyse",
        "cs": "vendor/bin/phpcs --standard=PSR12 src/",
        "cs-fix": "vendor/bin/phpcbf --standard=PSR12 src/"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}